listen     = "0.0.0.0:5555"
listen_tcp = "0.0.0.0:443"

[fec]
k = 20
r = 6

[tls]
# cert_file = "/etc/supervpn/server.crt"
# key_file  = "/etc/supervpn/server.key"
# If cert_file/key_file are omitted, a self-signed cert is generated automatically.

[[hub]]
id   = 1
name = "main"

  [[hub.user]]
  login         = "alice"
  password_hash = "$2a$10$replacethis"
